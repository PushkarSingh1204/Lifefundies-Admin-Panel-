# ─── LifeFundies Admin Panel — Environment Variables ──────────────────────────
#
# INSTRUCTIONS:
#   1. Copy this file: `cp .env.example .env`
#   2. Fill in the values from your Firebase Project Settings console
#   3. NEVER commit your .env file — it is listed in .gitignore
#
# ─── Firebase (lifefundies project) ──────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME=LifeFundies
VITE_APP_URL=http://localhost:5174

# ─── Razorpay (test keys from dashboard.razorpay.com) ─────────────────────────
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here
